<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>🎮 豪华版贪吃蛇</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="game-container">
        <div class="game-header">
            <div class="score-panel">
                🍎 <span id="scoreDisplay">0</span>
            </div>
            <div class="btn-group">
                <button class="btn btn-start" id="startBtn">▶ 开始</button>
                <button class="btn" id="restartBtn">⟳ 重来</button>
            </div>
        </div>

        <div class="canvas-wrapper">
            <canvas id="gameCanvas" width="400" height="400"></canvas>
        </div>

        <!-- 移动端触控按钮 -->
        <div class="touch-controls">
            <div class="touch-row">
                <button class="touch-btn" data-dir="up">⬆</button>
            </div>
            <div class="touch-row">
                <button class="touch-btn" data-dir="left">⬅</button>
                <button class="touch-btn" data-dir="down">⬇</button>
                <button class="touch-btn" data-dir="right">➡</button>
            </div>
        </div>

        <div class="footer-tip">
            <kbd>↑</kbd> <kbd>↓</kbd> <kbd>←</kbd> <kbd>→</kbd> 或 <kbd>W</kbd><kbd>A</kbd><kbd>S</kbd><kbd>D</kbd> 控制方向
        </div>
    </div>
    <script src="script.js"></script>
</body>
</html>
